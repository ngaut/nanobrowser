{
  "name": "chrome-extension",
  "version": "0.1.6",
  "description": "chrome extension - core settings",
  "type": "module",
  "scripts": {
    "clean:node_modules": "pnpx rimraf node_modules",
    "clean:turbo": "rimraf .turbo",
    "clean": "pnpm clean:turbo && pnpm clean:node_modules",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:debug": "vite build --mode development",
    "dev": "cross-env __DEV__=true vite build --mode development",
    "dev:watch": "cross-env __DEV__=true vite build --mode development --watch",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ./ --ext .ts,.js,.tsx,.jsx",
    "lint:fix": "pnpm lint --fix",
    "prettier": "prettier . --write --ignore-path ../.prettierignore",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "validate": "pnpm type-check && pnpm lint && pnpm test",
    "dev:tools": "node scripts/dev-tools.cjs"
  },
  "dependencies": {
    "@extension/shared": "workspace:*",
    "@extension/storage": "workspace:*",
    "@langchain/anthropic": "0.3.20",
    "@langchain/core": "0.3.56",
    "@langchain/deepseek": "^0.0.1",
    "@langchain/google-genai": "0.2.9",
    "@langchain/ollama": "^0.2.0",
    "@langchain/openai": "0.5.10",
    "@langchain/xai": "^0.0.2",
    "puppeteer-core": "24.8.2",
    "webextension-polyfill": "^0.12.0",
    "zod": "3.24.4",
    "zod-to-json-schema": "3.24.5"
  },
  "overrides": {
    "@langchain/core": "0.3.56"
  },
  "devDependencies": {
    "@extension/dev-utils": "workspace:*",
    "@extension/hmr": "workspace:*",
    "@extension/tsconfig": "workspace:*",
    "@extension/vite-config": "workspace:*",
    "@laynezh/vite-plugin-lib-assets": "^0.6.1",
    "@types/chrome": "0.0.323",
    "@types/cypress": "^1.1.6",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.1.4",
    "cross-env": "^7.0.3",
    "cypress": "^14.4.0",
    "deepmerge": "^4.3.1",
    "jsdom": "^26.1.0",
    "magic-string": "^0.30.10",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "ts-loader": "^9.5.1",
    "vitest": "^3.1.4"
  }
}
